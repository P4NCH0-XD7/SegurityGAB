# ==========================================
# SegurityGAB Backend - Environment Variables
# ==========================================

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_NAME=seguritygab
DB_PASSWORD=Admin01@

# JWT Authentication
JWT_SECRET=jwt_secret
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# AWS S3 (Image Uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=seguritygab-uploads

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
